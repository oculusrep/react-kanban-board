# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Database Connection
DB_PASSWORD=your_database_password_here
DATABASE_URL=postgresql://postgres.rqbvcvwbziilnycqtmnc:${DB_PASSWORD}@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://rqbvcvwbziilnycqtmnc.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Resend Email (for critical dates)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=notifications@oculusrep.com

# Dropbox
DROPBOX_ACCESS_TOKEN=your_dropbox_token_here
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token_here

# Brandfetch (Logo API + Search API) — public client_id, used by Merchants map layer
# Obtained from https://developers.brandfetch.com/dashboard/keys ("Client IDs" section)
# Note: this is NOT a secret — it appears in browser-visible CDN URLs. Safe to expose client-side.
VITE_BRANDFETCH_CLIENT_ID=your_brandfetch_client_id_here
