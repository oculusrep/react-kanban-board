node_modules
node_modules/
node_modules/

# Build output (contains bundled code with potential secrets)
dist/
build/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/

# Environment variables (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# API Keys and Secrets
*.key
*.pem

# Design references (screenshots can be large)
design-references/*.png
design-references/*.jpg
design-references/*.jpeg
design-references/*.gif
design-references/*.pdf
design-references/*.webp
!design-references/README.md

# Screenshots folder (should not be committed)
Screen Shots/
screenshots/

# Top-level Images/ is not served (Vite only serves public/). Belongs in public/Images/.
/Images/

# macOS Finder metadata
.DS_Store

# Database backups (contain sensitive data, too large for git)
backups/
*.sql.gz
*.dump

# Exclude all SQL files except migrations
*.sql
!supabase/migrations/*.sql
!supabase/CLEAN_SLATE_PAYMENT_TRIGGERS.sql
!supabase/RESTORE_ALL_PAYMENT_TRIGGERS.sql
!supabase/TEST_REFERRAL_FEE_CALCULATION.sql
!supabase/deal_submit_stage_backfill.sql
!supabase/deal_submit_stage_outliers.sql

# Archive folder (old troubleshooting files)
supabase/archive/

# Supabase CLI temp files
supabase/.temp/

# Restaurant Trends ETL / Starbucks data — never commit source files
data/incoming/
data/processed/
etl/config.yaml
*.xlsx
*.csv

# Test/debug scripts that may contain hardcoded credentials
check-*.js
query-*.js
test-*.js
debug-*.js

.vercel
scripts/setUserPassword.js

# Local Netlify folder
.netlify
.env*.local

# Claude startup script
start-claude.sh
.mcp.json
